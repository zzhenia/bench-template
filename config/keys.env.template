# keys.env is gitignored and never committed.

# ── Your Name ────────────────────────────────────────────────────────────────
# Displayed in the Actions Dashboard header (e.g. "Ben's Actions Dashboard")
BENCH_OWNER=

# ── Jira ──────────────────────────────────────────────────────────────────────
JIRA_URL=https://your-workspace.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEYS=PROJ

# ── Asana ─────────────────────────────────────────────────────────────────────
