{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/prompt_session_note.sh",
            "if": "Bash(git push*)",
            "timeout": 15,
            "statusMessage": "Checking session note..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/check_ai_annotations.sh",
            "timeout": 5,
            "statusMessage": "Checking for @ai annotations..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/scripts/session-note.sh",
            "timeout": 10,
            "statusMessage": "Session note reminder..."
          }
        ]
      }
    ]
  }
}
